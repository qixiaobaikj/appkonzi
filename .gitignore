# Gradle 编译输出
.gradle/
build/
**/build/
**/intermediates/
**/outputs/
**/tmp/
**/generated/

# Gradle wrapper jar (需要保留)
!gradle/wrapper/gradle-wrapper.jar
!gradle/wrapper/gradle-wrapper.properties

# 保留 build.gradle 文件
!*.gradle
!*.gradle.kts
!gradle.properties

# Android Studio / IntelliJ IDEA
*.iml
.idea/
.vscode/
captures/
.externalNativeBuild
.cxx/

# 本地配置（包含用户特定路径）
local.properties

# 生成的APK和AAB
*.apk
*.aab
*.ap_
*.dex
*.class

# 日志文件
*.log
*.hprof

# 系统文件
.DS_Store
Thumbs.db
desktop.ini

# 临时文件
*.tmp
*.bak
*.swp
*.swo
*~

# 环境配置
.env
.env.local

# Node.js (server目录)
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# keystore签名文件（敏感信息）
*.jks
*.keystore
keystore.properties

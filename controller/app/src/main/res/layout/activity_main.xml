<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_background"
    tools:context=".ui.MainActivity">

    <!-- 顶部标题栏 -->
    <LinearLayout
        android:id="@+id/layoutToolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="48dp"
        android:paddingBottom="12dp"
        android:background="@color/color_surface"
        android:gravity="center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 应用标题 -->
        <TextView
            android:id="@+id/tvTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/title_device_list"
            android:textColor="@color/color_on_background"
            android:textSize="22sp"
            android:textStyle="bold"
            android:letterSpacing="0.02" />

        <!-- 设置按钮（打开连接配置） -->
        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginEnd="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_preferences"
            android:contentDescription="@string/btn_settings"
            android:tint="@color/color_on_surface" />

        <!-- 添加设备按钮 -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAddDevice"
            android:layout_width="wrap_content"
            android:layout_height="36dp"
            android:text="@string/btn_add_device"
            android:textSize="13sp"
            android:paddingHorizontal="12dp"
            app:cornerRadius="18dp"
            app:backgroundTint="@color/color_primary"
            android:textColor="@color/color_on_primary" />

    </LinearLayout>

    <!-- 服务器连接卡片 -->
    <com.google.android.material.card.MaterialCardView
        android:id="@+id/cardServerConnect"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="16dp"
        android:layout_marginTop="12dp"
        app:cardBackgroundColor="@color/color_card"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:strokeColor="@color/color_divider"
        app:strokeWidth="1dp"
        app:layout_constraintTop_toBottomOf="@id/layoutToolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="12dp"
            android:gravity="center_vertical">

            <!-- 服务器地址输入框 -->
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/tilServerAddress"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginEnd="8dp"
                app:boxBackgroundColor="@color/color_surface_variant"
                app:boxBackgroundMode="filled"
                app:boxCornerRadiusTopStart="8dp"
                app:boxCornerRadiusTopEnd="8dp"
                app:boxCornerRadiusBottomStart="8dp"
                app:boxCornerRadiusBottomEnd="8dp"
                app:hintTextColor="@color/color_text_secondary"
                style="@style/Widget.MaterialComponents.TextInputLayout.FilledBox.Dense">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etServerAddress"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="@string/hint_server_address"
                    android:inputType="textUri"
                    android:textColor="@color/color_on_background"
                    android:textColorHint="@color/color_text_secondary"
                    android:textSize="13sp"
                    android:singleLine="true" />

            </com.google.android.material.textfield.TextInputLayout>

            <!-- 连接按钮 -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConnect"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/btn_connect"
                android:textSize="14sp"
                android:paddingHorizontal="16dp"
                app:cornerRadius="8dp"
                app:backgroundTint="@color/color_primary"
                android:textColor="@color/color_on_primary" />

        </LinearLayout>

    </com.google.android.material.card.MaterialCardView>

    <!-- 设备列表标题 -->
    <TextView
        android:id="@+id/tvDeviceListTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="20dp"
        android:layout_marginTop="16dp"
        android:text="在线设备"
        android:textColor="@color/color_text_secondary"
        android:textSize="12sp"
        android:letterSpacing="0.08"
        app:layout_constraintTop_toBottomOf="@id/cardServerConnect"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- 设备列表 RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerDevices"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:clipToPadding="false"
        android:paddingHorizontal="16dp"
        android:paddingBottom="80dp"
        app:layout_constraintTop_toBottomOf="@id/tvDeviceListTitle"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:listitem="@layout/item_device" />

    <!-- 空状态提示 -->
    <LinearLayout
        android:id="@+id/layoutEmpty"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        app:layout_constraintTop_toBottomOf="@id/tvDeviceListTitle"
        app:layout_constraintBottom_toTopOf="@id/layoutStatusBar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:visibility="visible">

        <ImageView
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@android:drawable/ic_menu_search"
            android:alpha="0.3"
            android:contentDescription="空状态图标" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/label_no_devices"
            android:textColor="@color/color_on_surface"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/label_no_devices_hint"
            android:textColor="@color/color_text_secondary"
            android:textSize="13sp"
            android:gravity="center"
            android:paddingHorizontal="32dp" />

    </LinearLayout>

    <!-- 底部连接状态栏 -->
    <LinearLayout
        android:id="@+id/layoutStatusBar"
        android:layout_width="0dp"
        android:layout_height="52dp"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingHorizontal="20dp"
        android:background="@color/color_surface"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <!-- 状态指示点 -->
        <View
            android:id="@+id/viewStatusDot"
            android:layout_width="10dp"
            android:layout_height="10dp"
            android:layout_marginEnd="10dp"
            android:background="@drawable/bg_status_dot_red" />

        <!-- 状态文字 -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/label_server_disconnected"
            android:textColor="@color/color_text_secondary"
            android:textSize="13sp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
